        "from scipy import stats\n",
        "\n",
        "# Test 1: T-test — Is avg profit different between Technology vs Furniture?\n",
        "tech   = df[df[\"Category\"]==\"Technology\"][\"Profit\"]\n",
        "furn   = df[df[\"Category\"]==\"Furniture\"][\"Profit\"]\n",
        "t, p = stats.ttest_ind(tech, furn)\n",
        "print(f\"H0: μ_tech = μ_furniture\\nt={t:.3f}, p={p:.4f}\")\n",
        "print(\"Reject H0\" if p < 0.05 else \"Fail to reject H0\")\n",
        "\n",
        "# Test 2: Mann-Whitney U — High Discount vs Low Discount profit\n",
        "high = df[df[\"High_Discount\"]==1][\"Profit\"]\n",
        "low  = df[df[\"High_Discount\"]==0][\"Profit\"]\n",
        "u, p2 = stats.mannwhitneyu(high, low, alternative=\"two-sided\")\n",
        "print(f\"\\nH0: No diff between high/low discount profit\\nU={u:.1f}, p={p2:.4f}\")\n",
        "print(\"Reject H0\" if p2 < 0.05 else \"Fail to reject H0\")"
